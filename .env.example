# BitLink21 v2 Environment Configuration
# Copy this file to .env and adjust values as needed
# WARNING: .env file contains secrets and should NOT be committed to git

# ============================================================================
# Server Port
# ============================================================================
BITLINK21_PORT=7000
# The port the BitLink21 web UI + API is accessible on

# ============================================================================
# PlutoSDR Hardware Configuration
# ============================================================================
PLUTO_URI=ip:192.168.1.200
# Alternative formats: tcp:192.168.1.200, usb:0, usb:1

# ============================================================================
# Bitcoin Core RPC (optional — for Bitcoin TX relay)
# ============================================================================
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASS=change-me

# ============================================================================
# LND REST API (optional — for Lightning invoice relay)
# ============================================================================
LND_REST_URL=
# Example: https://localhost:8080

# ============================================================================
# Build Information (set during docker build)
# ============================================================================
GIT_COMMIT=
BUILD_DATE=
BUILD_VERSION=2.0.0
