# BitLink21 Environment Configuration
# Copy this file to .env and adjust values as needed
# WARNING: .env file contains secrets and should NOT be committed to git

# ============================================================================
# PlutoSDR Hardware Configuration
# ============================================================================
PLUTO_URI=ip:192.168.1.200
# Alternative formats: tcp:192.168.1.200, usb:0, usb:1

# ============================================================================
# API Security
# ============================================================================
BITLINK_API_TOKEN=change-me-to-strong-secret
# Generate a secure token: openssl rand -hex 32

# ============================================================================
# Internal Container Communication
# ============================================================================
MODEM_PORT=40132
MODEM_IP=bitlink21-core
# These are used for UDP/TCP communication between radio and core containers

# ============================================================================
# Bitcoin/Lightning Network Configuration
# ============================================================================
BITCOIN_RPC_URL=http://localhost:18332
LIGHTNING_REST_URL=http://localhost:8080

# ============================================================================
# Database Configuration
# ============================================================================
DB_PATH=/app/data/bitlink21.db

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8021

# ============================================================================
# Web UI Configuration
# ============================================================================
REACT_APP_API_URL=http://localhost:8021

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
